DATABASE_URL=postgresql+asyncpg://crypto:crypto@localhost:5432/crypto_sentiment
BINANCE_API_BASE=https://api.binance.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
KLINE_CACHE_TTL_SECONDS=30

# X (Twitter) data source credentials. Leave blank for the ones you don't use.

# Official X API v2 bearer token. Used by tests/try_x_search.py.
X_BEARER_TOKEN=

# twitterapi.io API key. Used by tests/try_twitterapi_io.py and by
# GET /api/cryptos/{symbol}/posts when the UI fetches X posts. When empty,
# the API falls back to mock fixture data.
TWITTERAPI_IO_KEY=

# Apify API token. Used by tests/try_apify.py.
APIFY_TOKEN=

# OpenRouter API key for AI price predictions (POST /api/cryptos/{symbol}/predict).
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
OPENROUTER_MODELS=openai/gpt-4o-mini,openai/gpt-4o,anthropic/claude-3.5-sonnet,google/gemini-2.0-flash-001
