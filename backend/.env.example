DATABASE_URL=postgresql+asyncpg://crypto:crypto@localhost:5432/crypto_sentiment
BINANCE_API_BASE=https://api.binance.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
KLINE_CACHE_TTL_SECONDS=30

# X (Twitter) data source credentials. Leave blank for the ones you don't use.

# Official X API v2 bearer token. Used by tests/try_x_search.py.
X_BEARER_TOKEN=

# twitterapi.io API key. Used by tests/try_twitterapi_io.py AND by the
# background X-posts fetcher in production code. When empty, the periodic
# fetcher is silently disabled and the app boots normally.
TWITTERAPI_IO_KEY=

# Apify API token. Used by tests/try_apify.py.
APIFY_TOKEN=

# Background X-posts fetcher tuning. Comma-separated Binance pair symbols.
X_FETCH_SYMBOLS=BTCUSDT,ETHUSDT,DOGEUSDT
X_FETCH_INTERVAL_SECONDS=3600
X_FETCH_LIMIT_PER_SYMBOL=20
X_FETCH_LOOKBACK_HOURS=24
X_FETCH_LANG=en
